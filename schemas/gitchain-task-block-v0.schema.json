{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/gitchain-task-block-v0.schema.json",
  "title": "GitChain Task Block v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "version",
    "cycle_id",
    "slot",
    "minute",
    "task",
    "result_state",
    "public_summary",
    "candidate_type",
    "evidence_hash",
    "previous_task_hash",
    "task_hash",
    "timestamp",
    "public_safety"
  ],
  "properties": {
    "kind": { "type": "string", "enum": ["TASK_BLOCK"] },
    "version": { "type": "string", "enum": ["v0"] },
    "cycle_id": { "type": "string", "minLength": 3, "maxLength": 120 },
    "slot": { "type": "string", "pattern": "^slot[0-9]{2}$" },
    "minute": { "type": "integer", "minimum": 0, "maximum": 59 },
    "task": { "type": "string", "minLength": 3, "maxLength": 160 },
    "result_state": { "type": "string" },
    "public_summary": { "type": "string", "minLength": 3, "maxLength": 500 },
    "candidate_type": { "type": "string" },
    "evidence_hash": { "type": "string", "pattern": "^sha256:[A-Za-z0-9._:-]+$" },
    "previous_task_hash": { "type": "string", "pattern": "^sha256:[A-Za-z0-9._:-]+$" },
    "task_hash": { "type": "string", "pattern": "^sha256:[A-Za-z0-9._:-]+$" },
    "timestamp": { "type": "string", "minLength": 10, "maxLength": 80 },
    "public_safety": { "type": "string" }
  }
}
